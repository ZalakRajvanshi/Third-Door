# Copy to .env.local and fill in what you have. The app runs WITHOUT any of these
# (it falls back to seed data + heuristic ranking). Fill them in to go real.

# ── Supabase (internal profiles) ──────────────────────────────────────────────
# Dashboard → Settings → API. Use the SECRET key (not the publishable one).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ── AI (any OpenAI-compatible provider — Grok/xAI, Groq, OpenAI, OpenRouter…) ──
# Enables real intent parsing + AI ranking. Leave blank to use heuristics.
AI_API_KEY=
AI_BASE_URL=https://api.x.ai/v1
AI_MODEL=grok-2-latest

# ── Embeddings (OPTIONAL — turns on semantic search) ──────────────────────────
# Your stored vectors are OpenAI 1536-dim, so the model MUST match (text-embedding-3-small).
# Also run supabase/match_profiles.sql once in the Supabase SQL editor.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# ── Apify (external sourcing — only used as gap-fill when the DB lacks matches) ──
APIFY_TOKEN=
# The actor to run, e.g. apimaestro~linkedin-profile-search (use ~ not /)
APIFY_ACTOR_ID=
